--7. 5 produk yang punya presentasi tertinggi pengguna discount
select 
  item_purchased,
  round((sum(case when discount_applied = 'Yes' then 1 else 0 end)/count(*)) * 100, 2) as discount_rate
  --kenapa menggunakan case karena discount_applied string agar dapat dihitung pengguna discount ya maka di jadikan 1
  --yes, jika count() dia akan menghitung nilai 0 juga padahal yang diminta hanya nilai 1
from `rock-figure-339413.Data3.customer_shopping_behavior`
group by 1
order by 2 desc
limit 5

--8. Apa 3 produk yang sering dibeli di setiap kategory
--di setiap category cari produk yang paling banyak dibeli maksimal 3 produk yang paling laris
with item_count as(
  select 
  category, 
  item_purchased,
  count(customer_id) as Total_order,
  row_number() over(partition by category order by count(customer_id) desc) as item_rank
  from `rock-figure-339413.Data3.customer_shopping_behavior`
  group by 1, 2
)

select item_rank, category, item_purchased, Total_order
from item_count
where item_rank <= 3

--9. buat segment sutomer meliputi new, returning, dan loyal berdasarkan jumlah pelanggan
with customer_type as (
  select 
    customer_id,
    previous_purchases,
    case 
      when previous_purchases = 1 then 'New'
      when previous_purchases between 2 and 10 then 'Returning'
      else 'Loyal'
      end as customer_segment
from `rock-figure-339413.Data3.customer_shopping_behavior`
)
select customer_segment, count(*) as jumlah_pelanggan
from customer_type
group by 1


--10. Apakah customer yang belanja lebih dari 5 kali akan jadi pelanggan
select 
  subscription_status,
  count(*) as repeat_buyers,
  round((count(*)/sum(count(*)) over()) *100, 2) as repeat_rate
  --count(*) itu misalnya yes=300, no=200 total semua 500 jadi sum(count(*)) itu 500 itu menghitung % yang repeat
  --order di setiap yang berlangganan dan tidak
from `rock-figure-339413.Data3.customer_shopping_behavior`
where previous_purchases >= 5
group by 1
order by 2

