--3. Yang mana customer menggunakan discount tapi masih menghabiskan lebih dari rata rata total seluruh pembelian(nominal)
select 
  customer_id,
  purchase_amount
from `rock-figure-339413.Data3.customer_shopping_behavior`
where discount_applied = 'Yes' 
and purchase_amount >= (select avg(purchase_amount) from `rock-figure-339413.Data3.customer_shopping_behavior`)
order by 2 asc
limit 10

--4. 5 product terbaik yang tertinggi rata-rata reviewnya
select
  distinct(item_purchased),
  round(avg(review_rating), 2) as avg_review_rating,
from `rock-figure-339413.Data3.customer_shopping_behavior`
group by 1
order by 2 desc
limit 5
--menggunakan window 
select
  item_purchased,
  round(avg(review_rating), 2) as avg_review_rating,
  row_number() over (order by round(avg(review_rating), 2) desc ) as rank_avg_review_rating
from `rock-figure-339413.Data3.customer_shopping_behavior`
group by 1
limit 5

--5. bandingkan rata-rata jumlah pembelian(nominal) berdasarrkan pada pengiriman standar dan ekpress
select 
  shipping_type,
  round(avg(purchase_amount), 2) as avg_purchase_amount
from `rock-figure-339413.Data3.customer_shopping_behavior`
where shipping_type in ('Standard', 'Express')
