--6. Apakah pelanggan yang berlangganan lebih banyak, antara pelanggan dan bukan pelanggan 
--bandingkan denganrata-rata dan total pendapatan
select
  subscription_status,
  count(customer_id) as total_customers,
  round(avg(purchase_amount), 2) as avg_purchase_amount,
  round(sum(purchase_amount), 2) as total_purchase_amount,
from `rock-figure-339413.Data3.customer_shopping_behavior`
